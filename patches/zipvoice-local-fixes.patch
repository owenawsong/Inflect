+def format_duration(seconds: float | None) -> str:
+    if seconds is None or not math.isfinite(seconds):
+        return "unknown"
+    seconds = max(0, int(seconds))
+    hours, rem = divmod(seconds, 3600)
+    minutes, secs = divmod(rem, 60)
+    if hours > 0:
+        return f"{hours:d}h{minutes:02d}m{secs:02d}s"
+    if minutes > 0:
+        return f"{minutes:d}m{secs:02d}s"
+    return f"{secs:d}s"
+
+
+def progress_stats(params: AttributeDict) -> tuple[str, float | None, float | None, str]:
+    elapsed = time.time() - params.run_start_time
+    steps_done = max(0, int(params.batch_idx_train))
+    steps_per_sec = (steps_done / elapsed) if elapsed > 0 and steps_done > 0 else None
+    eta_seconds = None
+    progress = "unknown"
+    if params.num_iters and params.num_iters > 0:
+        clamped_steps = min(steps_done, params.num_iters)
+        progress = f"{clamped_steps}/{params.num_iters} ({100.0 * clamped_steps / params.num_iters:.1f}%)"
+        if steps_per_sec and steps_per_sec > 0 and steps_done < params.num_iters:
+            eta_seconds = (params.num_iters - steps_done) / steps_per_sec
+    else:
+        progress = f"{steps_done} steps"
+    return progress, elapsed, steps_per_sec, format_duration(eta_seconds)
+
